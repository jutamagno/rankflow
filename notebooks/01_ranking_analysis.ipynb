{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Ranking Analysis: Retrieval → Reranker Pipeline\n",
    "\n",
    "This notebook shows:\n",
    "1. How retrieval quality (NDCG) improves after reranking\n",
    "2. Latency breakdown between retrieval and reranking stages\n",
    "3. The cross-lingual penalty effect on multilingual catalogs\n",
    "4. IPS offline policy evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import time\n",
    "\n",
    "from src.evaluation.metrics import ndcg, mrr, hit_rate, evaluate_ranking, ips_policy_eval\n",
    "from src.reranker.ltr_model import LTRReranker, RankerFeatures, features_to_array\n",
    "\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "plt.rcParams['figure.dpi'] = 120\n",
    "rng = np.random.default_rng(42)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Simulate retrieval results and train a reranker"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "N_QUERIES = 300\n",
    "CANDIDATES_PER_QUERY = 50\n",
    "\n",
    "def simulate_retrieval(n_queries, n_candidates, seed=0):\n",
    "    \"\"\"Simulate retrieval stage: cosine similarity scores with noisy relevance.\"\"\"\n",
    "    rng = np.random.default_rng(seed)\n",
    "    queries, features_list, labels_list = [], [], []\n",
    "    \n",
    "    for q in range(n_queries):\n",
    "        true_relevance = rng.integers(0, 4, size=n_candidates)\n",
    "        # Retrieval score correlates with relevance but has noise\n",
    "        retrieval_scores = true_relevance / 3.0 + rng.normal(0, 0.3, n_candidates)\n",
    "        retrieval_scores = np.clip(retrieval_scores, 0, 1)\n",
    "        \n",
    "        feats = [\n",
    "            RankerFeatures(\n",
    "                retrieval_score=float(retrieval_scores[i]),\n",
    "                bm25_score=float(rng.uniform(0, 10)),\n",
    "                title_query_overlap=float(rng.uniform(0, 0.5)),\n",
    "                category_match=float(rng.choice([0.0, 1.0])),\n",
    "                item_popularity=float(rng.uniform(0, 5)),\n",
    "                freshness=float(rng.uniform(0.3, 1.0)),\n",
    "                query_length=int(rng.integers(1, 8)),\n",
    "                cross_lingual=float(rng.choice([0.7, 1.0])),\n",
    "            )\n",
    "            for i in range(n_candidates)\n",
    "        ]\n",
    "        queries.append(q)\n",
    "        features_list.append(feats)\n",
    "        labels_list.append(true_relevance)\n",
    "    \n",
    "    return queries, features_list, labels_list\n",
    "\n",
    "queries, all_features, all_labels = simulate_retrieval(N_QUERIES, CANDIDATES_PER_QUERY)\n",
    "\n",
    "# Train/test split\n",
    "split = int(N_QUERIES * 0.7)\n",
    "train_q, test_q = queries[:split], queries[split:]\n",
    "train_feats, test_feats = all_features[:split], all_features[split:]\n",
    "train_labels, test_labels = all_labels[:split], all_labels[split:]\n",
    "\n",
    "# Prepare training arrays\n",
    "X_train = np.vstack([features_to_array(f) for f in train_feats])\n",
    "y_train = np.concatenate(train_labels)\n",
    "groups_train = [CANDIDATES_PER_QUERY] * split\n",
    "\n",
    "X_test = np.vstack([features_to_array(f) for f in test_feats])\n",
    "y_test_flat = np.concatenate(test_labels)\n",
    "\n",
    "print(f\"Training: {split} queries × {CANDIDATES_PER_QUERY} candidates = {X_train.shape[0]} samples\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "reranker = LTRReranker()\n",
    "scores = reranker.train(X_train, y_train, groups_train, num_rounds=200)\n",
    "print(\"Training complete. Best scores:\", scores)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. NDCG: Retrieval vs. Reranker"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "k_values = [1, 5, 10, 20]\n",
    "retrieval_ndcg = []\n",
    "reranker_ndcg  = []\n",
    "\n",
    "for q_feats, q_labels in zip(test_feats, test_labels):\n",
    "    # Retrieval order: sort by retrieval_score\n",
    "    retrieval_order = np.argsort([-f.retrieval_score for f in q_feats])\n",
    "    retrieval_relevances = q_labels[retrieval_order].tolist()\n",
    "    \n",
    "    # Reranker order\n",
    "    candidates = [f'item_{i}' for i in range(len(q_feats))]\n",
    "    ranked = reranker.rerank(candidates, q_feats, top_k=CANDIDATES_PER_QUERY)\n",
    "    ranked_ids = [int(item_id.split('_')[1]) for item_id, _ in ranked]\n",
    "    reranker_relevances = q_labels[ranked_ids].tolist()\n",
    "    \n",
    "    retrieval_ndcg.append([ndcg(retrieval_relevances, k) for k in k_values])\n",
    "    reranker_ndcg.append([ndcg(reranker_relevances, k) for k in k_values])\n",
    "\n",
    "retrieval_ndcg = np.mean(retrieval_ndcg, axis=0)\n",
    "reranker_ndcg  = np.mean(reranker_ndcg, axis=0)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "x = np.arange(len(k_values))\n",
    "width = 0.35\n",
    "ax.bar(x - width/2, retrieval_ndcg, width, label='Retrieval only', color='#3498db', alpha=0.85)\n",
    "ax.bar(x + width/2, reranker_ndcg,  width, label='+ LTR Reranker', color='#2ecc71', alpha=0.85)\n",
    "\n",
    "for i, (r, rr) in enumerate(zip(retrieval_ndcg, reranker_ndcg)):\n",
    "    gain = rr - r\n",
    "    ax.annotate(f'+{gain:.3f}', xy=(i + width/2, rr + 0.005), ha='center', fontsize=9, color='#27ae60')\n",
    "\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels([f'NDCG@{k}' for k in k_values])\n",
    "ax.set_ylabel('NDCG')\n",
    "ax.set_ylim(0, 1)\n",
    "ax.legend()\n",
    "ax.set_title('Retrieval vs. LTR Reranker — NDCG Improvement\\n(LambdaRank distilled from LLM relevance labels)', fontsize=11)\n",
    "plt.tight_layout()\n",
    "plt.savefig('figures/01_ndcg_comparison.png', bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Feature Importance — what the reranker learned"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "importance = reranker.feature_importance()\n",
    "sorted_imp = sorted(importance.items(), key=lambda x: x[1], reverse=True)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 4))\n",
    "names, vals = zip(*sorted_imp)\n",
    "colors = ['#2ecc71' if v == max(vals) else '#3498db' for v in vals]\n",
    "ax.barh(names, vals, color=colors)\n",
    "ax.set_xlabel('Feature importance (gain)')\n",
    "ax.set_title('LTR Reranker Feature Importance\\n(retrieval_score is the starting point; reranker adds value on top)', fontsize=11)\n",
    "plt.tight_layout()\n",
    "plt.savefig('figures/02_feature_importance.png', bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. IPS: Estimating Online Performance Without A/B Test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simulate a logged dataset from the retrieval-only policy\n",
    "# (what we'd have before deploying the reranker)\n",
    "N_LOG = 1000\n",
    "logged_actions = [f'item_{rng.integers(0, 50)}' for _ in range(N_LOG)]\n",
    "logged_rewards = rng.binomial(1, 0.05, N_LOG).astype(float)  # 5% CTR\n",
    "logged_probs   = [0.02] * N_LOG  # uniform retrieval policy\n",
    "\n",
    "# New reranker policy: gives higher probability to top items\n",
    "new_actions = [f'item_{rng.integers(0, 20)}' for _ in range(N_LOG)]  # more concentrated\n",
    "new_probs   = [0.05] * N_LOG  # slightly higher for top items\n",
    "\n",
    "ips, snips = ips_policy_eval(logged_actions, logged_rewards, logged_probs, new_actions, new_probs, clip=10.0)\n",
    "\n",
    "print(f\"Logged policy reward:    {np.mean(logged_rewards):.4f}\")\n",
    "print(f\"IPS estimate (new):      {ips:.4f}\")\n",
    "print(f\"SNIPS estimate (new):    {snips:.4f}\")\n",
    "print(f\"\\nIPS says the new policy is {'better' if ips > np.mean(logged_rewards) else 'worse'} than the logged policy\")\n",
    "print(\"This estimate was made WITHOUT running an A/B test.\")"
   ]
  }
 ],
